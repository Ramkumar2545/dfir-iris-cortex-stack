# ============================================================
# DFIR-IRIS + Cortex — Environment Variables
# cp .env.example .env  then edit all CHANGE_ME values
#
# !! CRITICAL: Variable names must be EXACTLY as written here !!
# Wrong name (e.g. IRIS_SECRET_KEY) = None in app config
# = TypeError: encoding without a string argument in worker
#
# !! DO NOT add SERVER_NAME here — it breaks nginx upstream !!
# The IRIS nginx image uses SERVER_NAME to build "upstream app:<port>"
# If the value has no port or is blank it produces: invalid port in upstream ":"
# SERVER_NAME is set directly in docker-compose.yml under nginx environment:
# ============================================================

# — IRIS Version ————————————————————————————————————————
IRIS_VERSION=v2.4.20

# — PostgreSQL ——————————————————————————————————————————
POSTGRES_USER=iris
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_ADMIN_USER=iris_admin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_admin_password
POSTGRES_DB=iris_db

# — IRIS App Secrets ————————————————————————————————————
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# !! Must be SECRET_KEY and SECURITY_PASSWORD_SALT — NOT IRIS_ prefixed !!
SECRET_KEY=CHANGE_ME_secret_key_min_32_chars
SECURITY_PASSWORD_SALT=CHANGE_ME_password_salt

# — IRIS DB connection (mirrors POSTGRES_* above) ————————
DB_PASS=CHANGE_ME_db_password
DB_USER=iris
DB_NAME=iris_db
DB_HOST=db

# — Nginx / TLS —————————————————————————————————————————
# !! SERVER_NAME must NOT be set here — set in docker-compose nginx environment !!
INTERFACE_HTTPS_PORT=443
CERT_FILENAME=iris.crt
KEY_FILENAME=iris.key
IRIS_AUTHENTICATION_TYPE=local

# — Cortex Integration ——————————————————————————————————
# Obtain from: Cortex UI → Organization → Users → API Keys
CORTEX_API_KEY=CHANGE_ME_cortex_api_key
